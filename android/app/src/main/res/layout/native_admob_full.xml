<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none">

    <FrameLayout
        android:id="@+id/flNativeAds"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerHorizontal="true">

        <com.google.android.gms.ads.nativead.NativeAdView
            android:id="@+id/ad_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:scrollbars="none">

                <com.google.android.gms.ads.nativead.MediaView
                    android:id="@+id/ad_media"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="center_horizontal"
                    android:scrollbars="none"
                    app:layout_constraintBottom_toTopOf="@+id/ad_details"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <FrameLayout
                    android:id="@+id/ad_details"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_117sdp"
                    android:layout_centerHorizontal="true"
                    android:layout_margin="@dimen/_3sdp"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <RelativeLayout
                        android:id="@+id/admob_background"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_above="@+id/btn_card"
                            android:layout_marginRight="@dimen/_5sdp"
                            android:layout_marginBottom="@dimen/_3sdp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/ad_attribution"
                                android:layout_width="@dimen/_18sdp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentLeft="true"
                                android:layout_gravity="right"
                                android:background="#FF6F5F"
                                android:gravity="center"
                                android:fontFamily="@font/lexendmedium"
                                android:text="Ad"
                                android:textColor="#131622"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="@dimen/_20sdp"
                                android:layout_marginTop="@dimen/_3sdp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:gravity="center">

                                    <ImageView
                                        android:id="@+id/ad_icon"
                                        android:layout_width="@dimen/_40sdp"
                                        android:layout_height="@dimen/_40sdp" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_marginLeft="@dimen/_5sdp"
                                    android:gravity="center_vertical"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/ad_headline"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:lines="1"
                                        android:fontFamily="@font/lexendbold"
                                        android:textColor="#FF6F5F"
                                        android:textSize="@dimen/_12sdp"
                                        android:textStyle="bold" />

                                    <LinearLayout
                                        android:id="@+id/star_lay"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:id="@+id/ad_advertiser"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:ellipsize="end"
                                            android:lines="1"
                                            android:textColor="#E0DFDF"
                                            android:textSize="13sp" />

                                        <RatingBar
                                            android:id="@+id/ad_stars"
                                            style="?android:attr/ratingBarStyleSmall"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:isIndicator="true"
                                            android:numStars="5"
                                            android:stepSize="0.5"
                                            android:theme="@style/RatingBar" />
                                    </LinearLayout>

                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:id="@+id/ad_body"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:fontFamily="@font/lexendregular"
                                        android:lines="3"
                                        android:textColor="#ffffff"
                                        android:textSize="@dimen/_8sdp" />

                                </LinearLayout>

                            </LinearLayout>

                        </RelativeLayout>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_card"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_45sdp"
                            android:layout_alignParentBottom="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="@dimen/_15sdp"
                            android:layout_marginBottom="@dimen/_8sdp"
                            android:gravity="center"
                            app:cardCornerRadius="@dimen/_30sdp">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/ad_call_to_action"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#FF6F5F"
                                android:gravity="center"
                                android:paddingLeft="20dp"
                                android:paddingRight="20dp"
                                android:text=""
                                android:textColor="#ffffff"
                                android:fontFamily="@font/lexendmedium"
                                android:maxLines="1"
                                android:textSize="@dimen/_14sdp" />

                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.gms.ads.nativead.NativeAdView>

    </FrameLayout>

</com.google.android.gms.ads.nativead.NativeAdView>